generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum NotificationCategory {
  APPLICATION_STATUS
  JOB_ALERT
  SYSTEM
}

model Notification {
  id        String               @id @default(cuid())
  userId    String // Targeted user (candidate or recruiter)
  title     String
  message   String
  type      NotificationType     @default(INFO)
  category  NotificationCategory @default(SYSTEM)
  isRead    Boolean              @default(false)
  metadata  Json? // Additional info like applicationId, jobId
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([userId])
  @@index([isRead])
  @@index([userId, isRead])
}
