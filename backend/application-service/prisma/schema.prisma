// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


enum ApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  SHORTLISTED
  INTERVIEW_SCHEDULED
  INTERVIEWED
  OFFERED
  HIRED
  REJECTED
  WITHDRAWN
}

model Application {
  id                         String              @id @default(cuid())
  authUserId                 String
  jobId                      String
  companyId                  String

  status                     ApplicationStatus   @default(SUBMITTED)

  jobTitleSnapshot           String
  jobSlugSnapshot            String
  companyNameSnapshot        String
  jobLocationSnapshot        String?
  employmentTypeSnapshot     String?
  workplaceTypeSnapshot      String?

  candidateNameSnapshot      String
  candidateEmailSnapshot     String
  candidatePhoneSnapshot     String?
  candidateHeadlineSnapshot  String?
  candidateResumeUrlSnapshot String?
  candidateExperienceSummary String?

  coverLetter                String?
  screeningAnswers           Json?

  recruiterNotes             String?
  recruiterRating            Int?
  appliedAt                  DateTime            @default(now())
  reviewedAt                 DateTime?
  shortlistedAt              DateTime?
  interviewScheduledAt       DateTime?
  interviewedAt              DateTime?
  offeredAt                  DateTime?
  hiredAt                    DateTime?
  rejectedAt                 DateTime?
  withdrawnAt                DateTime?

  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt

  statusHistory              ApplicationStatusHistory[]

  @@index([authUserId])
  @@index([jobId])
  @@index([companyId])
  @@index([status])
  @@index([companyId, status])
  @@index([jobId, status])
  @@unique([authUserId, jobId])
}

model ApplicationStatusHistory {
  id              String            @id @default(cuid())
  applicationId   String
  fromStatus      ApplicationStatus?
  toStatus        ApplicationStatus
  changedByUserId String
  note            String?
  createdAt       DateTime          @default(now())

  application     Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}